+"""S2 FIX 2: one validated completion authority, proven on the real store.
+
+The lease store exposes only the fenced ``atomic_update`` primitive; S5's
+``submit_candidate_result``/``complete_job`` (ExecutionResultV1
+signature/schema/canonical-hash validation) are the single public
+result/completion authority composed on it.
+"""
+
+from __future__ import annotations
+
+import hashlib
+import json
+from datetime import UTC, datetime
+from pathlib import Path
+from uuid import uuid4
+
+import pytest
+from nacl.signing import SigningKey
+
+from tests.test_execution_result import create_result, result_body
+from tinyassets.branch_tasks import BranchTask
+from tinyassets.runtime.blob_refs import BlobStore
+from tinyassets.runtime.lease_store import (
+    Lease,
+    LeaseStore,
+    RecordReference,
+    ResultConflictError,
+)
+
+_OWNER = "user:owner-1"
+_DAEMON = "daemon:builder-1"
+_DEVICE_KEY = "device-key:builder-1"
+
+
+def _leased_job(tmp_path: Path) -> tuple[LeaseStore, BranchTask, Lease]:
+    store = LeaseStore(tmp_path / "leases.sqlite3")
+    task = BranchTask(
+        branch_task_id=str(uuid4()),
+        branch_def_id="branch-loop",
+        universe_id="universe-a",
+        queued_at="2026-07-19T12:00:00Z",
+    )
+    store.add_task(
+        task,
+        result_state={
+            "owner_user_id": _OWNER,
+            "device_key_id": _DEVICE_KEY,
+            "capability_class": "repo",
+            "repo_mode": "coding",
+            "runner_policy_sha256": "c" * 64,
+            "image_digest": f"sha256:{'d' * 64}",
+            "candidate_result": None,
+            "candidate_receipt": None,
+            "completion_receipt": None,
+        },
+    )
+    lease = store.claim(
+        task.branch_task_id,
+        daemon_id=_DAEMON,
+        bind_capsule=lambda _identity: RecordReference(str(uuid4()), "a" * 64),
+        lease_seconds=3600,
+    )
+    return store, task, lease
+
+
+def _signed_candidate(tmp_path: Path, task: BranchTask, lease: Lease):
+    body = result_body()
+    body["job_id"] = task.branch_task_id
+    body["capsule_id"] = lease.capsule.record_id
+    body["capsule_sha256"] = lease.capsule.content_sha256
+    body["lease_id"] = lease.lease_id
+    body["fence"] = lease.fence
+    blob_store = BlobStore(
+        tmp_path / "blobs",
+        max_blob_bytes=1024,
+        owner_quota_bytes=4096,
+        daemon_quota_bytes=4096,
+    )
+    for field, content in (
+        (body["repo_patch"], b"patch bytes"),
+        (body["logs"][0], b"stdout bytes"),
+    ):
+        sha256 = hashlib.sha256(content).hexdigest()
+        field["blob_sha256"] = sha256
+        field["blob_ref"] = f"blob:sha256:{sha256}"
+        field["size_bytes"] = len(content)
+        declared = {
+            "sha256": sha256,
+            "size_bytes": len(content),
+            "media_type": "application/octet-stream",
+            "confidentiality": "public",
+            "job_id": task.branch_task_id,
+            "lease_id": lease.lease_id,
+            "fence": lease.fence,
+        }
+        upload = blob_store.init_blob(declared, owner_user_id=_OWNER, daemon_id=_DAEMON)
+        blob_store.write_upload(upload.upload_id, content)
+        blob_store.commit_blob(upload.upload_id, owner_user_id=_OWNER, daemon_id=_DAEMON)
+    key = SigningKey.generate()
+    result, _ = create_result(body, key)
+    return blob_store, key, result
+
+
+def _completion_request(task: BranchTask, lease: Lease, result_sha256: str) -> dict:
+    return {
+        "job_id": task.branch_task_id,
+        "daemon_id": _DAEMON,
+        "lease_id": lease.lease_id,
+        "fence": lease.fence,
+        "capsule_sha256": lease.capsule.content_sha256,
+        "result_sha256": result_sha256,
+    }
+
+
+def test_s5_validated_candidate_and_completion_on_real_lease_store(tmp_path: Path) -> None:
+    """The validated authority composes with the store's fenced primitive."""
+    from tinyassets.api.execution_jobs import complete_job, submit_candidate_result
+
+    store, task, lease = _leased_job(tmp_path)
+    blob_store, key, result = _signed_candidate(tmp_path, task, lease)
+
+    receipt = submit_candidate_result(
+        store,
+        job_id=task.branch_task_id,
+        raw_result=json.dumps(result, separators=(",", ":")).encode(),
+        verify_key=key.verify_key,
+        device_key_active=True,
+        blob_store=blob_store,
+        now=datetime.now(UTC),
+    )
+    assert receipt.result_sha256 == result["signature"]["result_sha256"]
+
+    completion = complete_job(
+        store,
+        _completion_request(task, lease, receipt.result_sha256),
+        now=datetime.now(UTC),
+    )
+    persisted = store.read_task(task.branch_task_id)
+    assert completion.status == "succeeded"
+    assert persisted.status == "succeeded"
+    assert persisted.accepted_result_sha256 == receipt.result_sha256
+    kinds = [event.kind for event in store.events(task.branch_task_id)]
+    assert kinds == ["added", "claimed", "result_submitted", "completed"]
+
+
+def test_no_unvalidated_completion_path_exists(tmp_path: Path) -> None:
+    """Mutation-RED: pre-fix, ``store.submit_result``/``store.complete``
+    finalized an opaque reference with NO ExecutionResultV1 validation. Those
+    authorities are removed, and the one remaining door (``complete_job``)
+    rejects a completion carrying no validated candidate chain."""
+    from tinyassets.api.execution_jobs import CompletionConflictError, complete_job
+
+    store, task, lease = _leased_job(tmp_path)
+
+    with pytest.raises(AttributeError):
+        store.submit_result(
+            task.branch_task_id,
+            daemon_id=_DAEMON,
+            lease_id=lease.lease_id,
+            fence=lease.fence,
+            capsule_sha256=lease.capsule.content_sha256,
+            result=RecordReference(str(uuid4()), "0" * 64),
+        )
+    with pytest.raises(AttributeError):
+        store.complete(
+            task.branch_task_id,
+            daemon_id=_DAEMON,
+            lease_id=lease.lease_id,
+            fence=lease.fence,
+            capsule_sha256=lease.capsule.content_sha256,
+            result=RecordReference(str(uuid4()), "0" * 64),
+            status="succeeded",
+        )
+
+    with pytest.raises(CompletionConflictError):
+        complete_job(
+            store,
+            _completion_request(task, lease, "0" * 64),
+            now=datetime.now(UTC),
+        )
+
+    persisted = store.read_task(task.branch_task_id)
+    assert persisted.status == "leased"
+    assert persisted.candidate_result_sha256 == ""
+    assert persisted.accepted_result_sha256 == ""
+    kinds = [event.kind for event in store.events(task.branch_task_id)]
+    assert kinds == ["added", "claimed"]
+
+
+def test_atomic_primitive_rejects_accepting_a_non_candidate(tmp_path: Path) -> None:
+    """Even the fenced primitive enforces accepted == validated candidate."""
+    store, task, _lease = _leased_job(tmp_path)
+
+    def forged_finalize(state):
+        updated = dict(state)
+        updated["status"] = "succeeded"
+        updated["accepted_result_sha256"] = "9" * 64
+        return updated, "forged"
+
+    with pytest.raises(ResultConflictError):
+        store.atomic_update(task.branch_task_id, forged_finalize)
+    assert store.read_task(task.branch_task_id).status == "leased"
