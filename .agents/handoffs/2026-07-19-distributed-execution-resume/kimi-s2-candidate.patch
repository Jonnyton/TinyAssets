+def _queue_capsule_reference(task: BranchTask) -> Callable:
+    """Pure, content-addressed capsule binder for the queue claim path.
+
+    The legacy daemon has no external capsule store, so the binder
+    derives a deterministic reference from the task bytes and the lease
+    identity, and persists NOTHING — combined with the post-CAS bind
+    order in ``LeaseStore.claim``, a losing claimant leaves no orphan
+    capsule behind.
+    """
+
+    def bind(identity: Lease):
+        from tinyassets.runtime.lease_store import RecordReference
+
+        payload = json.dumps(
+            {
+                "task": task.to_dict(),
+                "lease_id": identity.lease_id,
+                "fence": identity.fence,
+                "daemon_id": identity.daemon_id,
+            },
+            sort_keys=True,
+            separators=(",", ":"),
+        )
+        digest = hashlib.sha256(payload.encode("utf-8")).hexdigest()
+        record_id = str(
+            uuid.uuid5(
+                uuid.NAMESPACE_URL,
+                f"tinyassets:queue-capsule:{identity.lease_id}",
+            )
+        )
+        return RecordReference(record_id=record_id, content_sha256=digest)
+
+    return bind
+
+
+def _claim_via_lease_store(
+    universe_path: Path,
+    task_id: str,
+    claimer: str,
+    task: BranchTask,
+) -> Lease | None:
+    """Grant ownership ONLY through the SQLite lease store's fenced CAS.
+
+    Returns the won ``Lease``, or ``None`` when the CAS is lost to
+    another claimant (this queue path or the S5 job path). The first
+    claim of an id syncs the enqueue into the store (idempotent for
+    byte-identical content); a blank/shared claimer fails closed via
+    ``InvalidLeaseHolderError``.
+    """
+    from tinyassets.runtime.lease_store import (
+        AlreadyClaimedError,
+        LeaseStore,
+        TaskConflictError,
+        TaskNotFoundError,
+    )
+
+    store = LeaseStore(lease_db_path(universe_path))
+    binder = _queue_capsule_reference(task)
+    try:
+        return store.claim(
+            task_id,
+            daemon_id=claimer,
+            bind_capsule=binder,
+            lease_seconds=DEFAULT_LEASE_SECONDS,
+        )
+    except AlreadyClaimedError:
+        return None
+    except TaskNotFoundError:
+        pass
+    try:
+        store.add_task(task)
+    except TaskConflictError:
+        # Another producer path holds this id under different content;
+        # the fenced CAS below remains the sole arbiter of ownership.
+        pass
+    try:
+        return store.claim(
+            task_id,
+            daemon_id=claimer,
+            bind_capsule=binder,
+            lease_seconds=DEFAULT_LEASE_SECONDS,
+        )
+    except AlreadyClaimedError:
+        return None
+
+
 def claim_task(
