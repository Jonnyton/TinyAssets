+"""S2 FIX 3: the SQLite lease is the SOLE claim authority.
+
+Pre-fix, the legacy JSON ``claim_task`` granted ownership by itself, so a JSON
+claimant and a SQLite claimant could both win the same task. ``claim_task``
+now routes the grant through ``LeaseStore.claim`` (and stamps the queue row
+as its projection). Each test below is mutation-RED against the pre-fix code.
+"""
+
+from __future__ import annotations
+
+from concurrent.futures import ThreadPoolExecutor
+from pathlib import Path
+from threading import Barrier
+from uuid import uuid4
+
+import pytest
+
+from tinyassets.branch_tasks import (
+    BranchTask,
+    append_task,
+    claim_task,
+    lease_db_path,
+    read_queue,
+)
+from tinyassets.runtime.lease_store import (
+    AlreadyClaimedError,
+    LeaseStore,
+    RecordReference,
+)
+
+
+def _task() -> BranchTask:
+    return BranchTask(
+        branch_task_id=str(uuid4()),
+        branch_def_id="branch-loop",
+        universe_id="universe-a",
+        queued_at="2026-07-19T12:00:00Z",
+    )
+
+
+def _bind(seed: str):
+    return lambda _identity: RecordReference(str(uuid4()), seed * 64)
+
+
+def test_json_claim_excludes_direct_sqlite_claim(tmp_path: Path) -> None:
+    """JSON claimant wins → the SQLite claimant loses the same CAS.
+
+    Mutation-RED: pre-fix the SQLite store never saw the JSON claim, so
+    ``store.claim`` WON and both authorities owned the task.
+    """
+    task = _task()
+    append_task(tmp_path, task)
+
+    claimed = claim_task(tmp_path, task.branch_task_id, "daemon-json")
+    assert claimed is not None
+    assert claimed.status == "running"
+    assert claimed.lease_fence == 1
+
+    store = LeaseStore(lease_db_path(tmp_path))
+    with pytest.raises(AlreadyClaimedError):
+        store.claim(
+            task.branch_task_id,
+            daemon_id="daemon-sqlite",
+            bind_capsule=_bind("b"),
+        )
+
+    persisted = store.read_task(task.branch_task_id)
+    assert persisted.lease_daemon_id == "daemon-json"
+    assert persisted.lease_fence == 1
+
+
+def test_sqlite_claim_excludes_json_claim(tmp_path: Path) -> None:
+    """SQLite claimant wins → the JSON claimant gets None, no ownership grant.
+
+    Mutation-RED: pre-fix ``claim_task`` flipped the queue row to ``running``
+    and returned a claimed task even though the lease was already held.
+    """
+    task = _task()
+    store = LeaseStore(lease_db_path(tmp_path))
+    store.add_task(task)
+    lease = store.claim(
+        task.branch_task_id,
+        daemon_id="daemon-sqlite",
+        bind_capsule=_bind("a"),
+    )
+    append_task(tmp_path, task)
+
+    assert claim_task(tmp_path, task.branch_task_id, "daemon-json") is None
+
+    row = read_queue(tmp_path)[0]
+    assert row.status == "pending"
+    assert row.claimed_by == ""
+    assert store.read_task(task.branch_task_id).lease_id == lease.lease_id
+
+
+def test_mixed_json_and_sqlite_claimants_have_exactly_one_winner(tmp_path: Path) -> None:
+    """A JSON-path claimant and a SQLite-path claimant race: exactly one wins."""
+    task = _task()
+    append_task(tmp_path, task)
+    store = LeaseStore(lease_db_path(tmp_path))
+    store.add_task(task)
+    barrier = Barrier(2)
+
+    def via_queue():
+        barrier.wait(timeout=5)
+        return claim_task(tmp_path, task.branch_task_id, "daemon-json")
+
+    def via_lease_store():
+        barrier.wait(timeout=5)
+        try:
+            return store.claim(
+                task.branch_task_id,
+                daemon_id="daemon-sqlite",
+                bind_capsule=_bind("c"),
+            )
+        except AlreadyClaimedError as exc:
+            return exc
+
+    with ThreadPoolExecutor(max_workers=2) as pool:
+        futures = (pool.submit(via_queue), pool.submit(via_lease_store))
+        queue_outcome = futures[0].result()
+        store_outcome = futures[1].result()
+
+    queue_won = queue_outcome is not None
+    store_won = not isinstance(store_outcome, Exception)
+    assert queue_won != store_won, "exactly one authority may own the task"
+
+    persisted = store.read_task(task.branch_task_id)
+    assert persisted.lease_fence == 1
+    row = read_queue(tmp_path)[0]
+    if queue_won:
+        assert persisted.lease_daemon_id == "daemon-json"
+        assert row.status == "running"
+        assert row.claimed_by == "daemon-json"
+    else:
+        assert persisted.lease_daemon_id == "daemon-sqlite"
+        assert row.status == "pending"
